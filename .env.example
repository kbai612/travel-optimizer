# Copy to .env and fill in. Both accounts are free.

# OpenSky Network — https://opensky-network.org (Account > API Client)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Travelpayouts — https://www.travelpayouts.com/programs/100/tools/api
# Pulls both the monthly and day-level calendar fare endpoints.
# (Amadeus Self-Service is gone: decommissioned 2026-07-17.)
TRAVELPAYOUTS_TOKEN=

# IATA code of your home departure airport, used for both Travelpayouts price pulls.
# Keep this stable if you want one continuous fare history; downstream only the
# latest origin's snapshots are used, so changing it resets comparability.
HOME_AIRPORT_IATA=JFK
